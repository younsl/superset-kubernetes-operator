# Note: Generated/scaffolded directories (config/) are removed from the
# Rat workdir by scripts/check_license.sh before Rat runs. This file
# handles remaining file-level exclusions.

# Git
.*\.gitignore
.*\.gitattributes

# Go
.*go\.mod
.*go\.sum

# Generated code
.*zz_generated\.deepcopy\.go

# Kustomize structural files
.*kustomization\.yaml
.*kustomizeconfig\.yaml
.*PROJECT

# Helm chart metadata
.*Chart\.yaml
.*values\.yaml

# Documentation
.*api-reference\.md
.*docs-requirements\.txt
.*mkdocs\.yml

# CI / tooling
.*PULL_REQUEST_TEMPLATE\.md
.*ISSUE_TEMPLATE/.*\.md
.*\.claude.*
# Editor/agent context symlinks → AGENTS.md (which carries the header itself)
CLAUDE\.md
GEMINI\.md
.*rat-results\.txt
.*Dockerfile\.cross
.*codecov\.yml
.*supported-k8s\.json
